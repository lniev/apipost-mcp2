{
  "name": "apipost-mcp",
  "version": "1.2.0",
  "description": "ApiPost MCP - API文档管理工具，支持接口创建、修改、查看、类型生成和批量操作",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node -r dotenv/config dist/index.js",
    "dev": "tsx src/index.ts",
    "watch": "tsx watch src/index.ts",
    "debugger": "npx @modelcontextprotocol/inspector tsx -r dotenv/config src/index.ts",
    "gen:mcp-json": "node scripts/gen-mcp-json.mjs",
    "setup:claude-code": "npm run gen:mcp-json && node scripts/setup-claude-code.mjs",
    "setup:codex": "npm run gen:mcp-json && node scripts/setup-codex.mjs"
  },
  "keywords": [
    "mcp",
    "apipost",
    "api",
    "documentation",
    "cursor",
    "type-generation",
    "claude-code"
  ],
  "author": "lniev <LnievV@outlook.com> (https://github.com/lniev)",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^0.4.0",
    "axios": "^1.6.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.21",
    "dotenv": "^17.4.2",
    "json-schema-to-typescript": "^15.0.4",
    "tsx": "^4.0.0",
    "typescript": "^5.9.3"
  }
}
